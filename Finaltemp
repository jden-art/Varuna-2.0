// --- MPU6050 State ---
struct MPU6050State {
    // Raw readings (16-bit signed)
    int16_t rawAccX, rawAccY, rawAccZ;
    int16_t rawGyroX, rawGyroY, rawGyroZ;
    int16_t rawTemp;

    // Physical units
    float accX_g, accY_g, accZ_g;         // in g
    float accX_mps2, accY_mps2, accZ_mps2; // in m/s²
    float gyroX_dps, gyroY_dps, gyroZ_dps; // in °/s

    // Calibration offsets
    float gyroOffsetX, gyroOffsetY, gyroOffsetZ;  // °/s offset
    float refAccX, refAccY, refAccZ;               // Reference gravity vector (g)
    float refTiltX, refTiltY;                      // Reference tilt angles (°)

    // Complementary filter output
    float filtTiltX, filtTiltY;                    // Filtered tilt (°)
    float correctedTiltX, correctedTiltY;          // After reference subtraction (°)
    float combinedTheta;                           // sqrt(corrX² + corrY²) (°)

    // Lateral acceleration for tether detection
    float lateralAccel;  // sqrt(ax² + ay²) in m/s²

    // Sensor status
    bool online;
    bool calibrated;

    // Timing
    unsigned long lastFusionMicros;
} mpu;

// --- BMP280 State ---
struct BMP280State {
    // Calibration coefficients (from chip)
    uint16_t dig_T1;
    int16_t  dig_T2, dig_T3;
    uint16_t dig_P1;
    int16_t  dig_P2, dig_P3, dig_P4, dig_P5;
    int16_t  dig_P6, dig_P7, dig_P8, dig_P9;
    int32_t  t_fine;

    // Current readings
    float pressure_hPa;      // Current pressure in hPa
    float temperature_C;     // Current temperature in °C

    // Baseline for submersion
    float baselinePressure_hPa;
    bool  baselineSet;

    // Derived
    float gaugePressure_Pa;  // (current - baseline) in Pa
    float estimatedDepth_cm; // Submersion depth in cm

    // Sensor status
    bool online;
} bmp;

// --- DS1307 RTC State ---
struct DS1307State {
    uint8_t seconds, minutes, hours;
    uint8_t dayOfWeek, date, month;
    uint16_t year;

    uint32_t unixTime;
    char dateTimeStr[24];  // "YYYY-MM-DD HH:MM:SS"

