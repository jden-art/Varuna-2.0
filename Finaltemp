// ============================================================================
// IMPLEMENTATION — MPU6050 LOW-LEVEL
// ============================================================================

bool mpuWriteReg(uint8_t reg, uint8_t val) {
    I2C_Bus0.beginTransmission(MPU6050_ADDR);
    I2C_Bus0.write(reg);
    I2C_Bus0.write(val);
    return (I2C_Bus0.endTransmission() == 0);
}

uint8_t mpuReadReg(uint8_t reg) {
    I2C_Bus0.beginTransmission(MPU6050_ADDR);
    I2C_Bus0.write(reg);
    I2C_Bus0.endTransmission(false);
    I2C_Bus0.requestFrom((uint8_t)MPU6050_ADDR, (uint8_t)1);
    if (I2C_Bus0.available()) {
        return I2C_Bus0.read();
    }
    return 0xFF;
}

void mpuReadSensorData() {
    if (!mpu.online) return;

    // Read 14 bytes starting from ACCEL_XOUT_H (accel[6] + temp[2] + gyro[6])
    I2C_Bus0.beginTransmission(MPU6050_ADDR);
    I2C_Bus0.write(MPU6050_REG_ACCEL_XOUT_H);
    if (I2C_Bus0.endTransmission(false) != 0) {
        mpu.online = false;
        sendErrorMsg("MPU6050 read failed — marking offline");
        return;
    }

    uint8_t bytesReceived = I2C_Bus0.requestFrom((uint8_t)MPU6050_ADDR, (uint8_t)14);
    if (bytesReceived != 14) {
        sendWarningMsg("MPU6050 incomplete read");
        return;
    }

    // Parse raw values (big-endian)
    mpu.rawAccX  = (I2C_Bus0.read() << 8) | I2C_Bus0.read();
    mpu.rawAccY  = (I2C_Bus0.read() << 8) | I2C_Bus0.read();
    mpu.rawAccZ  = (I2C_Bus0.read() << 8) | I2C_Bus0.read();
    mpu.rawTemp  = (I2C_Bus0.read() << 8) | I2C_Bus0.read();
    mpu.rawGyroX = (I2C_Bus0.read() << 8) | I2C_Bus0.read();
    mpu.rawGyroY = (I2C_Bus0.read() << 8) | I2C_Bus0.read();
    mpu.rawGyroZ = (I2C_Bus0.read() << 8) | I2C_Bus0.read();
}

void mpuConvertUnits() {
    // Accelerometer: raw to g
    mpu.accX_g = (float)mpu.rawAccX / ACCEL_SCALE_2G;
    mpu.accY_g = (float)mpu.rawAccY / ACCEL_SCALE_2G;
    mpu.accZ_g = (float)mpu.rawAccZ / ACCEL_SCALE_2G;

    // Accelerometer: g to m/s²
    mpu.accX_mps2 = mpu.accX_g * GRAVITY_MPS2;
    mpu.accY_mps2 = mpu.accY_g * GRAVITY_MPS2;
    mpu.accZ_mps2 = mpu.accZ_g * GRAVITY_MPS2;

    // Gyroscope: raw to °/s (with offset correction)
    mpu.gyroX_dps = ((float)mpu.rawGyroX / GYRO_SCALE_250DPS) - mpu.gyroOffsetX;
    mpu.gyroY_dps = ((float)mpu.rawGyroY / GYRO_SCALE_250DPS) - mpu.gyroOffsetY;
    mpu.gyroZ_dps = ((float)mpu.rawGyroZ / GYRO_SCALE_250DPS) - mpu.gyroOffsetZ;

    // Lateral acceleration magnitude (for tether detection)
    mpu.lateralAccel = sqrtf(mpu.accX_mps2 * mpu.accX_mps2 +
                             mpu.accY_mps2 * mpu.accY_mps2);
}

// ============================================================================
// IMPLEMENTATION — MPU6050 CALIBRATION
// ============================================================================

void calibrateGyroscope() {
    sendStatusMsg("Calibrating gyroscope — keep buoy stationary...");

    float sumX = 0, sumY = 0, sumZ = 0;
    int validSamples = 0;

    for (int i = 0; i < GYRO_CAL_SAMPLES; i++) {
        mpuReadSensorData();

        float gx = (float)mpu.rawGyroX / GYRO_SCALE_250DPS;
        float gy = (float)mpu.rawGyroY / GYRO_SCALE_250DPS;
        float gz = (float)mpu.rawGyroZ / GYRO_SCALE_250DPS;

        sumX += gx;
        sumY += gy;
        sumZ += gz;
        validSamples++;

        delayMicroseconds(1000);  // 1ms between samples
    }

    if (validSamples > 0) {
        mpu.gyroOffsetX = sumX / validSamples;
        mpu.gyroOffsetY = sumY / validSamples;
        mpu.gyroOffsetZ = sumZ / validSamples;
    }

    char msg[100];
    snprintf(msg, sizeof(msg), "Gyro calibration complete — offsets: X=%.3f Y=%.3f Z=%.3f °/s (%d samples)",
             mpu.gyroOffsetX, mpu.gyroOffsetY, mpu.gyroOffsetZ, validSamples);
    sendStatusMsg(msg);
}

void calibrateAccelerometer() {
    sendStatusMsg("Calibrating accelerometer — recording gravity reference...");

    float sumX = 0, sumY = 0, sumZ = 0;
    int validSamples = 0;

    for (int i = 0; i < ACCEL_CAL_SAMPLES; i++) {
        mpuReadSensorData();

        float ax = (float)mpu.rawAccX / ACCEL_SCALE_2G;
        float ay = (float)mpu.rawAccY / ACCEL_SCALE_2G;
        float az = (float)mpu.rawAccZ / ACCEL_SCALE_2G;

        // Validate: magnitude should be ~1g
        float mag = sqrtf(ax * ax + ay * ay + az * az);
        if (mag >= ACCEL_G_MIN && mag <= ACCEL_G_MAX) {
            sumX += ax;
            sumY += ay;
            sumZ += az;
            validSamples++;
        }

        delayMicroseconds(2000);  // 2ms between samples
    }

    if (validSamples > 100) {  // Need at least 100 valid samples
        mpu.refAccX = sumX / validSamples;
        mpu.refAccY = sumY / validSamples;
        mpu.refAccZ = sumZ / validSamples;

        // Compute reference tilt angles
        mpu.refTiltX = atan2f(mpu.refAccY,
                              sqrtf(mpu.refAccX * mpu.refAccX + mpu.refAccZ * mpu.refAccZ))
                       * 180.0f / M_PI;

        mpu.refTiltY = atan2f(-mpu.refAccX,
                              sqrtf(mpu.refAccY * mpu.refAccY + mpu.refAccZ * mpu.refAccZ))
                       * 180.0f / M_PI;

        mpu.calibrated = true;

        char msg[128];
        snprintf(msg, sizeof(msg),
                 "Accel calibration complete — ref: X=%.4f Y=%.4f Z=%.4f g, refTilt: X=%.2f Y=%.2f° (%d samples)",
                 mpu.refAccX, mpu.refAccY, mpu.refAccZ,
                 mpu.refTiltX, mpu.refTiltY, validSamples);
        sendStatusMsg(msg);
    } else {
        sendErrorMsg("Accelerometer calibration failed — too few valid samples (excessive vibration?)");
        mpu.calibrated = false;
    }
}

void recalibrate() {
    sendStatusMsg("Full recalibration starting...");
    calibrateGyroscope();
    calibrateAccelerometer();

    // Reset filter state
    mpu.filtTiltX = 0.0f;
    mpu.filtTiltY = 0.0f;
    mpu.lastFusionMicros = micros();

    sendStatusMsg("Recalibration complete — filter state reset");
}

// ============================================================================
// IMPLEMENTATION — BMP280 LOW-LEVEL
// ============================================================================

bool bmpWriteReg(uint8_t reg, uint8_t val) {
    I2C_Bus1.beginTransmission(BMP280_ADDR);
    I2C_Bus1.write(reg);
    I2C_Bus1.write(val);
    return (I2C_Bus1.endTransmission() == 0);
}

uint8_t bmpReadReg(uint8_t reg) {
    I2C_Bus1.beginTransmission(BMP280_ADDR);
    I2C_Bus1.write(reg);
    I2C_Bus1.endTransmission(false);
    I2C_Bus1.requestFrom((uint8_t)BMP280_ADDR, (uint8_t)1);
    if (I2C_Bus1.available()) {
        return I2C_Bus1.read();
    }
    return 0xFF;
}

void bmpReadCalibration() {
    // Read 26 bytes of calibration data starting at 0x88
    uint8_t calData[26];

    I2C_Bus1.beginTransmission(BMP280_ADDR);
    I2C_Bus1.write(BMP280_REG_CALIB_START);
    I2C_Bus1.endTransmission(false);
    I2C_Bus1.requestFrom((uint8_t)BMP280_ADDR, (uint8_t)26);

    for (int i = 0; i < 26; i++) {
        calData[i] = I2C_Bus1.available() ? I2C_Bus1.read() : 0;
    }

    // Parse calibration values (little-endian)
    bmp.dig_T1 = (uint16_t)(calData[1] << 8 | calData[0]);
    bmp.dig_T2 = (int16_t)(calData[3] << 8 | calData[2]);
    bmp.dig_T3 = (int16_t)(calData[5] << 8 | calData[4]);
    bmp.dig_P1 = (uint16_t)(calData[7] << 8 | calData[6]);
    bmp.dig_P2 = (int16_t)(calData[9] << 8 | calData[8]);
    bmp.dig_P3 = (int16_t)(calData[11] << 8 | calData[10]);
    bmp.dig_P4 = (int16_t)(calData[13] << 8 | calData[12]);
    bmp.dig_P5 = (int16_t)(calData[15] << 8 | calData[14]);
    bmp.dig_P6 = (int16_t)(calData[17] << 8 | calData[16]);
    bmp.dig_P7 = (int16_t)(calData[19] << 8 | calData[18]);
    bmp.dig_P8 = (int16_t)(calData[21] << 8 | calData[20]);
    bmp.dig_P9 = (int16_t)(calData[23] << 8 | calData[22]);

    sendStatusMsg("BMP280 calibration coefficients loaded");
}

float bmpCompensateTemp(int32_t adc_T) {
    // BMP280 compensation formula from datasheet
    int32_t var1, var2;

    var1 = ((((adc_T >> 3) - ((int32_t)bmp.dig_T1 << 1))) * ((int32_t)bmp.dig_T2)) >> 11;
    var2 = (((((adc_T >> 4) - ((int32_t)bmp.dig_T1)) *
              ((adc_T >> 4) - ((int32_t)bmp.dig_T1))) >> 12) *
            ((int32_t)bmp.dig_T3)) >> 14;

    bmp.t_fine = var1 + var2;
    float T = (bmp.t_fine * 5 + 128) >> 8;
    return T / 100.0f;
}

float bmpCompensatePressure(int32_t adc_P) {
    // BMP280 compensation formula from datasheet
    int64_t var1, var2, p;

    var1 = ((int64_t)bmp.t_fine) - 128000;
    var2 = var1 * var1 * (int64_t)bmp.dig_P6;
    var2 = var2 + ((var1 * (int64_t)bmp.dig_P5) << 17);
    var2 = var2 + (((int64_t)bmp.dig_P4) << 35);
    var1 = ((var1 * var1 * (int64_t)bmp.dig_P3) >> 8) +
           ((var1 * (int64_t)bmp.dig_P2) << 12);
    var1 = (((((int64_t)1) << 47) + var1)) * ((int64_t)bmp.dig_P1) >> 33;

    if (var1 == 0) return 0.0f;  // Avoid division by zero

    p = 1048576 - adc_P;
    p = (((p << 31) - var2) * 3125) / var1;
    var1 = (((int64_t)bmp.dig_P9) * (p >> 13) * (p >> 13)) >> 25;
    var2 = (((int64_t)bmp.dig_P8) * p) >> 19;

    p = ((p + var1 + var2) >> 8) + (((int64_t)bmp.dig_P7) << 4);
    return (float)p / 25600.0f;  // Result in hPa
}

void bmpReadData() {
    if (!bmp.online) return;

    // Read 6 bytes: pressure (3) + temperature (3) starting at 0xF7
    I2C_Bus1.beginTransmission(BMP280_ADDR);
    I2C_Bus1.write(BMP280_REG_PRESS_MSB);
    if (I2C_Bus1.endTransmission(false) != 0) {
        bmp.online = false;
        sendErrorMsg("BMP280 read failed — marking offline");
        return;
    }

    uint8_t data[6];
    I2C_Bus1.requestFrom((uint8_t)BMP280_ADDR, (uint8_t)6);
    for (int i = 0; i < 6; i++) {
        data[i] = I2C_Bus1.available() ? I2C_Bus1.read() : 0;
    }

    // Parse 20-bit raw values
    int32_t rawPress = ((int32_t)data[0] << 12) | ((int32_t)data[1] << 4) | (data[2] >> 4);
    int32_t rawTemp  = ((int32_t)data[3] << 12) | ((int32_t)data[4] << 4) | (data[5] >> 4);

    // Compensate (temperature must be computed first — sets t_fine)
    bmp.temperature_C = bmpCompensateTemp(rawTemp);
    bmp.pressure_hPa = bmpCompensatePressure(rawPress);

    // Compute gauge pressure and depth
    if (bmp.baselineSet) {
        bmp.gaugePressure_Pa = (bmp.pressure_hPa - bmp.baselinePressure_hPa) * 100.0f;  // hPa to Pa
        if (bmp.gaugePressure_Pa > 0.0f) {
            bmp.estimatedDepth_cm = (bmp.gaugePressure_Pa * SUBMERSION_DEPTH_FACTOR) * 100.0f;  // m to cm
        } else {
            bmp.estimatedDepth_cm = 0.0f;
        }
    }
}

void bmpEstablishBaseline() {
    if (!bmp.online) {
        sendWarningMsg("Cannot establish pressure baseline — BMP280 offline");
        return;
    }

    sendStatusMsg("Establishing atmospheric pressure baseline (50 samples)...");

    float sum = 0.0f;
    int validCount = 0;

    for (int i = 0; i < BASELINE_PRESSURE_SAMPLES; i++) {
        bmpReadData();

        // Sanity check: sea level pressure range 870-1084 hPa
        if (bmp.pressure_hPa > 870.0f && bmp.pressure_hPa < 1084.0f) {
            sum += bmp.pressure_hPa;
            validCount++;
        }

        delay(100);
    }

    if (validCount >= 30) {
        bmp.baselinePressure_hPa = sum / validCount;
        bmp.baselineSet = true;

        char msg[80];
        snprintf(msg, sizeof(msg), "Baseline pressure set: %.2f hPa (%d valid samples)",
                 bmp.baselinePressure_hPa, validCount);
        sendStatusMsg(msg);
    } else {
        sendErrorMsg("Pressure baseline failed — insufficient valid samples");
    }
}

// ============================================================================
// IMPLEMENTATION — DS1307 RTC
// ============================================================================

uint8_t bcdToDec(uint8_t bcd) {
    return ((bcd >> 4) * 10) + (bcd & 0x0F);
}

uint8_t decToBcd(uint8_t dec) {
    return ((dec / 10) << 4) | (dec % 10);
}

void rtcReadTime() {
    if (!rtc.online) return;

    I2C_Bus1.beginTransmission(DS1307_ADDR);
    I2C_Bus1.write(DS1307_REG_SECONDS);
    if (I2C_Bus1.endTransmission() != 0) {
        rtc.online = false;
        sendErrorMsg("DS1307 read failed — marking offline");
        return;
    }

    I2C_Bus1.requestFrom((uint8_t)DS1307_ADDR, (uint8_t)7);
    if (I2C_Bus1.available() < 7) {
        sendWarningMsg("DS1307 incomplete read");
        return;
    }

    uint8_t secReg = I2C_Bus1.read();
    rtc.seconds   = bcdToDec(secReg & 0x7F);  // Mask CH bit
    rtc.minutes   = bcdToDec(I2C_Bus1.read());
    uint8_t hourReg = I2C_Bus1.read();
    // Handle 12/24 hour mode
    if (hourReg & 0x40) {
        // 12-hour mode
        rtc.hours = bcdToDec(hourReg & 0x1F);
        if (hourReg & 0x20) rtc.hours += 12;  // PM
    } else {
        rtc.hours = bcdToDec(hourReg & 0x3F);
    }
    rtc.dayOfWeek = bcdToDec(I2C_Bus1.read());
    rtc.date      = bcdToDec(I2C_Bus1.read());
    rtc.month     = bcdToDec(I2C_Bus1.read());
    rtc.year      = 2000 + bcdToDec(I2C_Bus1.read());

    // Validate
    if (rtc.year >= 2024 && rtc.year <= 2035 &&
        rtc.month >= 1 && rtc.month <= 12 &&
        rtc.date >= 1 && rtc.date <= 31 &&
        rtc.hours <= 23 && rtc.minutes <= 59 && rtc.seconds <= 59) {
        rtc.valid = true;
    } else {
        rtc.valid = false;
    }

    rtcComputeUnixTime();
    rtcFormatDateTime();
}

uint32_t rtcComputeUnixTime() {
    // Simplified Unix time calculation
    // Days from 1970-01-01 to current date
    uint16_t y = rtc.year;
    uint8_t m = rtc.month;
    uint8_t d = rtc.date;

    // Days in each month (non-leap)
    static const uint16_t monthDays[] = {0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334};

    uint32_t days = 0;

    // Years since 1970
    for (uint16_t yr = 1970; yr < y; yr++) {
        days += 365;
        if ((yr % 4 == 0 && yr % 100 != 0) || (yr % 400 == 0)) {
            days++;
        }
    }

    // Months in current year
    if (m > 0 && m <= 12) {
        days += monthDays[m - 1];
    }

    // Leap year adjustment for current year
    if (m > 2 && ((y % 4 == 0 && y % 100 != 0) || (y % 400 == 0))) {
        days++;
    }

    days += (d - 1);

    rtc.unixTime = days * 86400UL + (uint32_t)rtc.hours * 3600UL +
                   (uint32_t)rtc.minutes * 60UL + (uint32_t)rtc.seconds;

    return rtc.unixTime;
}

void rtcFormatDateTime() {
    snprintf(rtc.dateTimeStr, sizeof(rtc.dateTimeStr),
             "%04u-%02u-%02u %02u:%02u:%02u",
             rtc.year, rtc.month, rtc.date,
             rtc.hours, rtc.minutes, rtc.seconds);
}

// ============================================================================
// IMPLEMENTATION — GPS
// ============================================================================

void gpsProcessByte(uint8_t b) {
    if (b == '$') {
        gps.nmeaBufIdx = 0;
        gps.nmeaBuffer[gps.nmeaBufIdx++] = b;
    } else if (b == '\n' || b == '\r') {
        if (gps.nmeaBufIdx > 5) {
            gps.nmeaBuffer[gps.nmeaBufIdx] = '\0';
            gpsParseSentence(gps.nmeaBuffer);
        }
        gps.nmeaBufIdx = 0;
    } else if (gps.nmeaBufIdx < GPS_BUFFER_SIZE - 1) {
        gps.nmeaBuffer[gps.nmeaBufIdx++] = b;
    }
}

int gpsSplitFields(const char* sentence, char fields[][20], int maxFields) {
    int fieldIdx = 0;
    int charIdx = 0;

    for (int i = 0; sentence[i] != '\0' && fieldIdx < maxFields; i++) {
        if (sentence[i] == ',' || sentence[i] == '*') {
            fields[fieldIdx][charIdx] = '\0';
            fieldIdx++;
            charIdx = 0;
        } else if (charIdx < 19) {
            fields[fieldIdx][charIdx++] = sentence[i];
        }
    }
    // Terminate last field
    if (fieldIdx < maxFields) {
        fields[fieldIdx][charIdx] = '\0';
        fieldIdx++;
    }

    return fieldIdx;
}

float gpsConvertCoord(const char* raw, const char* dir) {
    if (raw[0] == '\0') return 0.0f;

    double val = atof(raw);
    int degrees = (int)(val / 100);
    double minutes = val - (degrees * 100.0);
    double decimal = degrees + (minutes / 60.0);

    if (dir[0] == 'S' || dir[0] == 'W') {
        decimal = -decimal;
    }

    return (float)decimal;
}

void gpsParseSentence(const char* sentence) {
    char fields[NMEA_MAX_FIELDS][20];
    memset(fields, 0, sizeof(fields));

    int numFields = gpsSplitFields(sentence, fields, NMEA_MAX_FIELDS);

    // Determine sentence type
    if (strstr(fields[0], "GGA") != NULL) {
        gpsParseGGA(sentence);
    } else if (strstr(fields[0], "RMC") != NULL) {
        gpsParseRMC(sentence);
    }
}

void gpsParseGGA(const char* sentence) {
    char fields[NMEA_MAX_FIELDS][20];
    memset(fields, 0, sizeof(fields));
    int n = gpsSplitFields(sentence, fields, NMEA_MAX_FIELDS);

    if (n < 15) return;

    // Field 1: Time (hhmmss.sss)
    if (strlen(fields[1]) >= 6) {
        gps.utcHour = (fields[1][0] - '0') * 10 + (fields[1][1] - '0');
        gps.utcMin  = (fields[1][2] - '0') * 10 + (fields[1][3] - '0');
        gps.utcSec  = (fields[1][4] - '0') * 10 + (fields[1][5] - '0');
    }

    // Field 2,3: Latitude, N/S
    gps.latitude = gpsConvertCoord(fields[2], fields[3]);

    // Field 4,5: Longitude, E/W
    gps.longitude = gpsConvertCoord(fields[4], fields[5]);

    // Field 6: Fix quality (0=invalid, 1=GPS, 2=DGPS)
    int fixQuality = atoi(fields[6]);
    gps.fixValid = (fixQuality >= 1);

    // Field 7: Number of satellites
    gps.satellites = (uint8_t)atoi(fields[7]);

    // Field 9: Altitude
    gps.altitude = atof(fields[9]);

    if (gps.fixValid) {
        gps.online = true;
    }
}

void gpsParseRMC(const char* sentence) {
    char fields[NMEA_MAX_FIELDS][20];
    memset(fields, 0, sizeof(fields));
    int n = gpsSplitFields(sentence, fields, NMEA_MAX_FIELDS);

    if (n < 12) return;

    // Field 1: Time
    if (strlen(fields[1]) >= 6) {
        gps.utcHour = (fields[1][0] - '0') * 10 + (fields[1][1] - '0');
        gps.utcMin  = (fields[1][2] - '0') * 10 + (fields[1][3] - '0');
        gps.utcSec  = (fields[1][4] - '0') * 10 + (fields[1][5] - '0');
    }

    // Field 2: Status A=valid, V=void
    gps.fixValid = (fields[2][0] == 'A');

    // Field 3,4: Latitude
    gps.latitude = gpsConvertCoord(fields[3], fields[4]);

    // Field 5,6: Longitude
    gps.longitude = gpsConvertCoord(fields[5], fields[6]);

    // Field 9: Date (ddmmyy)
    if (strlen(fields[9]) >= 6) {
        gps.utcDay   = (fields[9][0] - '0') * 10 + (fields[9][1] - '0');
        gps.utcMonth = (fields[9][2] - '0') * 10 + (fields[9][3] - '0');
        gps.utcYear  = 2000 + (fields[9][4] - '0') * 10 + (fields[9][5] - '0');
    }

    if (gps.fixValid) {
        gps.online = true;
    }
}

// ============================================================================
// IMPLEMENTATION — BATTERY
// ============================================================================

void readBattery() {
    uint32_t sum = 0;
    for (int i = 0; i < ADC_SAMPLES; i++) {
        sum += analogRead(BATTERY_ADC_PIN);
        delayMicroseconds(100);
    }
    uint32_t avgRaw = sum / ADC_SAMPLES;

    // Voltage divider: assuming 2:1 divider (100k/100k)
    // ADC reads 0-4095 for 0-3.3V
    // Actual voltage = ADC voltage × 2
    float adcVoltage = (avgRaw / 4095.0f) * 3.3f;
    battery.voltage = adcVoltage * 2.0f;  // Through voltage divider

    // LiPo percentage estimation (3.0V = 0%, 4.2V = 100%)
    float pct = (battery.voltage - 3.0f) / (4.2f - 3.0f) * 100.0f;
    if (pct > 100.0f) pct = 100.0f;
    if (pct < 0.0f) pct = 0.0f;
    battery.percent = pct;
}

// ============================================================================
// IMPLEMENTATION — COMPLEMENTARY FILTER (Sensor Fusion)
// ============================================================================

void runComplementaryFilter() {
    if (!mpu.online || !mpu.calibrated) return;

    unsigned long nowMicros = micros();
    float dt = (nowMicros - mpu.lastFusionMicros) / 1000000.0f;
    mpu.lastFusionMicros = nowMicros;

    // Guard against unreasonable dt
    if (dt <= 0.0f || dt > 0.5f) {
        dt = 0.01f;  // Default to 10ms
    }

    // ---- Accelerometer-derived angle ----
    // Tilt X: rotation around X-axis (pitch) — measures Y component against vertical
    float accelTiltX = atan2f(mpu.accY_g,
                              sqrtf(mpu.accX_g * mpu.accX_g + mpu.accZ_g * mpu.accZ_g))
                       * 180.0f / M_PI;

    // Tilt Y: rotation around Y-axis (roll) — measures X component against vertical
    float accelTiltY = atan2f(-mpu.accX_g,
                              sqrtf(mpu.accY_g * mpu.accY_g + mpu.accZ_g * mpu.accZ_g))
                       * 180.0f / M_PI;

    // ---- Complementary filter ----
    // Gyro integration + accel correction
    mpu.filtTiltX = ALPHA * (mpu.filtTiltX + mpu.gyroX_dps * dt)
                  + (1.0f - ALPHA) * accelTiltX;

    mpu.filtTiltY = ALPHA * (mpu.filtTiltY + mpu.gyroY_dps * dt)
                  + (1.0f - ALPHA) * accelTiltY;

    // ---- Apply reference correction ----
    mpu.correctedTiltX = mpu.filtTiltX - mpu.refTiltX;
    mpu.correctedTiltY = mpu.filtTiltY - mpu.refTiltY;

    // ---- Combined angle from vertical ----
    mpu.combinedTheta = sqrtf(mpu.correctedTiltX * mpu.correctedTiltX +
                              mpu.correctedTiltY * mpu.correctedTiltY);
}

// ============================================================================
// IMPLEMENTATION — FLOOD DETECTION
// ============================================================================

void computeWaterLevel() {
    float theta_rad = mpu.combinedTheta * M_PI / 180.0f;
    float L = flood.olpLength_cm;

    // H = L × cos(θ)
    flood.waterHeight_cm = L * cosf(theta_rad);

    // Horizontal distance: d = L × sin(θ)
    flood.horizontalDist_cm = L * sinf(theta_rad);

    // Flood ratio
    flood.floodRatio = flood.waterHeight_cm / L;

    // Clamp flood ratio
    if (flood.floodRatio > 1.0f) flood.floodRatio = 1.0f;
    if (flood.floodRatio < 0.0f) flood.floodRatio = 0.0f;

    // If submerged, add pressure-derived depth
    if (bmp.online && bmp.baselineSet && bmp.gaugePressure_Pa > thresholds.submersionPressurePa) {
        float totalHeight = L + bmp.estimatedDepth_cm;
        flood.waterHeight_cm = totalHeight;
        flood.floodRatio = totalHeight / L;
    }
}

void classifyMode() {
    uint8_t detectedMode;

    // Priority 1: Submersion (highest priority)
    if (bmp.online && bmp.baselineSet &&
        bmp.gaugePressure_Pa > thresholds.submersionPressurePa) {
        detectedMode = 3;  // SUBMERGED
    }
    // Priority 2: Check if tether is taut
    else if (mpu.lateralAccel > thresholds.lateralAccelTaut &&
             mpu.combinedTheta > thresholds.tiltTautMin) {
        // Tether is taut — check if flood or approaching
        if (mpu.combinedTheta < thresholds.floodTiltMax &&
            flood.floodRatio > thresholds.floodHRatio) {
            detectedMode = 2;  // FLOOD
        } else {
            detectedMode = 1;  // TAUT
        }
    }
    // Priority 3: Check slack with hysteresis
    else if (mpu.lateralAccel < thresholds.lateralAccelSlack ||
             mpu.combinedTheta < thresholds.tiltTautMin) {
        detectedMode = 0;  // SLACK
    }
    // Default: maintain current mode
    else {
        detectedMode = flood.currentMode;
    }

    // --- Persistence filter (debounce) ---
    if (detectedMode == flood.pendingMode) {
        flood.persistCount++;
    } else {
        flood.pendingMode = detectedMode;
        flood.persistCount = 1;
    }

    // Determine required persistence count
    int requiredPersist = MODE_PERSIST_NORMAL;
    if (detectedMode == 3) {
        requiredPersist = MODE_PERSIST_SUBMERGE;  // Faster for submersion
    }

    // Commit mode transition
    if (flood.persistCount >= requiredPersist && flood.currentMode != detectedMode) {
        char msg[80];
        snprintf(msg, sizeof(msg), "Mode transition: %d → %d (after %d readings)",
                 flood.currentMode, detectedMode, flood.persistCount);
        sendStatusMsg(msg);

        flood.currentMode = detectedMode;
    }
}

void updateAlertLevel() {
    switch (flood.currentMode) {
        case 0:  // SLACK
            flood.alertLevel = 0;   // GREEN
            flood.currentZone = 0;
            flood.responseLevel = 0;
            break;

        case 1:  // TAUT
            if (flood.floodRatio > 0.80f) {
                flood.alertLevel = 1;   // YELLOW (elevated)
                flood.responseLevel = 2;
            } else if (flood.floodRatio > 0.50f) {
                flood.alertLevel = 1;   // YELLOW
                flood.responseLevel = 1;
            } else {
                flood.alertLevel = 0;   // GREEN (taut but low)
                flood.responseLevel = 1;
            }
            flood.currentZone = 1;
            break;

        case 2:  // FLOOD
            flood.alertLevel = 2;   // RED
            flood.currentZone = 2;
            flood.responseLevel = 3;
            break;

        case 3:  // SUBMERGED
            flood.alertLevel = 3;   // BLACK (critical)
            flood.currentZone = 3;
            flood.responseLevel = 4;
            break;
    }

    // Sustained rise detection
    if (flood.rateOfRise_cm_per_15min > 1.0f && flood.floodRatio > 0.5f) {
        flood.sustainedRise = true;
    } else {
        flood.sustainedRise = false;
    }
}

void updateRateOfRise() {
    unsigned long now = millis();
    unsigned long elapsed = now - flood.lastRateCalcMs;

    // Calculate rate every 60 seconds minimum
    if (elapsed >= 60000) {
        float deltaH = flood.waterHeight_cm - flood.lastHeight_cm;
        float elapsedMin = elapsed / 60000.0f;

        // Normalize to cm per 15 minutes
        float ratePerMin = deltaH / elapsedMin;
        flood.rateOfRise_cm_per_15min = ratePerMin * 15.0f;

        flood.lastHeight_cm = flood.waterHeight_cm;
        flood.lastRateCalcMs = now;
    }
}

void updateSessionStats() {
    if (flood.currentMode >= 1) {
        // Only track when tether is taut (meaningful measurement)
        if (flood.waterHeight_cm > flood.peakHeight_cm) {
            flood.peakHeight_cm = flood.waterHeight_cm;
        }
        if (flood.waterHeight_cm < flood.minHeight_cm) {
            flood.minHeight_cm = flood.waterHeight_cm;
        }
    }
}

// ============================================================================
// IMPLEMENTATION — DYNAMIC SAMPLING
// ============================================================================

void computeTransmitInterval() {
    float ratio = flood.floodRatio;

    if (ratio >= RATE_TRANSITION_HIGH) {
        // Above 80%: use high rate
        sampling.currentIntervalSec = sampling.highRateSec;
    } else if (ratio <= RATE_TRANSITION_LOW) {
        // Below 50%: use normal rate
        sampling.currentIntervalSec = sampling.normalRateSec;
    } else {
        // 50-80%: linear interpolation
        float t = (ratio - RATE_TRANSITION_LOW) / (RATE_TRANSITION_HIGH - RATE_TRANSITION_LOW);
        sampling.currentIntervalSec = (uint32_t)(
            sampling.normalRateSec - t * (sampling.normalRateSec - sampling.highRateSec)
        );
    }

    sampling.sampleIntervalSec = sampling.currentIntervalSec;
}

bool isTransmitDue() {
    unsigned long now = millis();
    unsigned long intervalMs = (unsigned long)sampling.currentIntervalSec * 1000UL;

    if (now - sampling.lastTransmitMs >= intervalMs) {
        return true;
    }
    return false;
}

// ============================================================================
// IMPLEMENTATION — SOFTWARE UART (GPIO 14 → C3)
// ============================================================================

void c3UartSendByte(uint8_t byte) {
    // Disable interrupts for precise timing
    noInterrupts();

    // Start bit (LOW)
    digitalWrite(C3_DATA_TX_PIN, LOW);
    delayMicroseconds(SOFT_UART_BIT_TIME_US);

    // 8 data bits (LSB first)
    for (int i = 0; i < 8; i++) {
        if (byte & (1 << i)) {
            digitalWrite(C3_DATA_TX_PIN, HIGH);
        } else {
            digitalWrite(C3_DATA_TX_PIN, LOW);
        }
        delayMicroseconds(SOFT_UART_BIT_TIME_US);
    }

    // Stop bit (HIGH)
    digitalWrite(C3_DATA_TX_PIN, HIGH);
    delayMicroseconds(SOFT_UART_BIT_TIME_US);

    // Re-enable interrupts
    interrupts();
}

void c3UartSendString(const char* str) {
    while (*str) {
        c3UartSendByte((uint8_t)*str);
        str++;
    }
}

