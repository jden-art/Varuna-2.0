// IMPLEMENTATION — COMMAND PROCESSING (Debugger → S3)
// ============================================================================

void processDebugCommands() {
    while (Serial.available()) {
        char c = Serial.read();
        if (c == '\n' || c == '\r') {
            if (dbgCmdIdx > 0) {
                dbgCmdBuf[dbgCmdIdx] = '\0';
                handleDebugCommand(dbgCmdBuf);
                dbgCmdIdx = 0;
            }
        } else if (dbgCmdIdx < sizeof(dbgCmdBuf) - 1) {
            dbgCmdBuf[dbgCmdIdx++] = c;
        }
    }
}

void handleDebugCommand(const char* cmd) {
    char response[256];

    // --- PING ---
    if (strcmp(cmd, "PING") == 0) {
        sendStatusMsg("PONG");
        return;
    }

    // --- GETCONFIG ---
    if (strcmp(cmd, "GETCONFIG") == 0) {
        snprintf(response, sizeof(response),
                 "STATUS:CONFIG normal=%lus high=%lus L=%.1fcm mode=%d interval=%lus health=%d battery=%.1f%%",
                 (unsigned long)sampling.normalRateSec,
                 (unsigned long)sampling.highRateSec,
                 flood.olpLength_cm,
                 flood.currentMode,
                 (unsigned long)sampling.currentIntervalSec,
                 healthScore,
                 battery.percent);
        Serial.println(response);
        return;
    }

    // --- RECALIBRATE ---
    if (strcmp(cmd, "RECALIBRATE") == 0) {
        sendStatusMsg("Starting recalibration...");
        recalibrate();
        if (bmp.online) {
            bmpEstablishBaseline();
        }
        sendStatusMsg("Recalibration complete");
        return;
    }

    // --- GETTHRESH ---
    if (strcmp(cmd, "GETTHRESH") == 0) {
        snprintf(response, sizeof(response),
                 "STATUS:THRESH lateralTaut=%.3f lateralSlack=%.3f tiltMin=%.1f floodTilt=%.1f floodRatio=%.2f subPressure=%.1f",
                 thresholds.lateralAccelTaut,
                 thresholds.lateralAccelSlack,
                 thresholds.tiltTautMin,
                 thresholds.floodTiltMax,
                 thresholds.floodHRatio,
                 thresholds.submersionPressurePa);
        Serial.println(response);
        return;
    }

    // --- SETTHRESH=A,W,D ---
    // A = lateralAccelTaut, W = floodTiltMax, D = submersionPressurePa
    if (strncmp(cmd, "SETTHRESH=", 10) == 0) {
        float A, W, D;
        int parsed = sscanf(cmd + 10, "%f,%f,%f", &A, &W, &D);
        if (parsed == 3) {
            thresholds.lateralAccelTaut = A;
            thresholds.lateralAccelSlack = A * 0.67f;  // Auto-set hysteresis
            thresholds.floodTiltMax = W;
            thresholds.submersionPressurePa = D;

            snprintf(response, sizeof(response),
                     "STATUS:THRESH_SET A=%.3f W=%.1f D=%.1f",
                     A, W, D);
            Serial.println(response);
        } else {
            sendErrorMsg("SETTHRESH parse failed — expected SETTHRESH=A,W,D");
        }
        return;
    }

    // --- RESETTHRESH ---
    if (strcmp(cmd, "RESETTHRESH") == 0) {
        initThresholds();
        sendStatusMsg("Thresholds reset to defaults");
        return;
    }

    // --- SETAPN (placeholder — S3 doesn't handle SIM) ---
    if (strncmp(cmd, "SETAPN", 6) == 0) {
        // Forward to C3 if needed
        sendStatusMsg("SETAPN — S3 does not handle SIM. Forward to C3.");
        return;
    }

    // --- REINITSIM (placeholder) ---
    if (strcmp(cmd, "REINITSIM") == 0) {
        sendStatusMsg("REINITSIM — S3 does not handle SIM. Forward to C3.");
        return;
    }

    // --- TESTGPRS (placeholder) ---
    if (strcmp(cmd, "TESTGPRS") == 0) {
        sendStatusMsg("TESTGPRS — S3 does not handle SIM. Forward to C3.");
        return;
    }

    // --- Unknown ---
    snprintf(response, sizeof(response), "ERROR:Unknown command: %s", cmd);
    Serial.println(response);
}

// ============================================================================
// IMPLEMENTATION — DIAGNOSTICS
// ============================================================================

void checkDiagSchedule() {
    unsigned long now = millis();

    // Scheduled 24-hour diagnostic
    if (now - diag.lastDiagMs >= DIAG_INTERVAL_MS) {
        diag.diagRequested = true;
    }

    // Manual diagnostic requested
    if (diag.diagRequested) {
        diag.diagRequested = false;
        diag.lastDiagMs = now;
        runDiagnostic();
    }

    // Check PONG timeout during diagnostic
    if (diag.waitingForPong) {
        if (now - diag.pingSentMs >= DIAG_PING_TIMEOUT_MS) {
            diag.c3PongReceived = false;
            diag.waitingForPong = false;
            sendWarningMsg("C3 PONG timeout — communication link may be down");

            // Complete diagnostic with failed C3 link
            char diagFrame[512];
            buildDiagFrame(diagFrame, sizeof(diagFrame));
            sendDiagToC3(diagFrame);
        }
    }
}

void runDiagnostic() {
    sendStatusMsg("=== DIAGNOSTIC RUN STARTING ===");
    diag.totalFaults = 0;

    // --- MPU6050 Tests ---

    // Test 1: WHO_AM_I
    uint8_t whoami = mpuReadReg(MPU6050_REG_WHO_AM_I);
    diag.mpuWhoAmIOk = (whoami == MPU6050_WHO_AM_I_VALUE);
    if (!diag.mpuWhoAmIOk) {
        diag.totalFaults++;
        sendErrorMsg("DIAG: MPU6050 WHO_AM_I failed");
    }

    // Test 2: Accelerometer magnitude sanity
    if (mpu.online) {
        mpuReadSensorData();
        mpuConvertUnits();
        float mag = sqrtf(mpu.accX_g * mpu.accX_g +
                          mpu.accY_g * mpu.accY_g +
                          mpu.accZ_g * mpu.accZ_g);
        diag.mpuAccelOk = (mag > 0.7f && mag < 1.4f);
        if (!diag.mpuAccelOk) {
            diag.totalFaults++;
            char msg[64];
            snprintf(msg, sizeof(msg), "DIAG: Accel magnitude out of range: %.3f g", mag);
            sendErrorMsg(msg);
        }
    } else {
        diag.mpuAccelOk = false;
        diag.totalFaults++;
    }

    // Test 3: Gyro drift measurement (should be near zero when stationary)
    if (mpu.online) {
        float sumGx = 0, sumGy = 0, sumGz = 0;
        for (int i = 0; i < 50; i++) {
            mpuReadSensorData();
            mpuConvertUnits();
            sumGx += fabsf(mpu.gyroX_dps);
            sumGy += fabsf(mpu.gyroY_dps);
            sumGz += fabsf(mpu.gyroZ_dps);
            delayMicroseconds(1000);
        }
        float avgDrift = (sumGx + sumGy + sumGz) / 150.0f;
        diag.mpuGyroOk = (avgDrift < 5.0f);  // Less than 5°/s average drift
        if (!diag.mpuGyroOk) {
            diag.totalFaults++;
            sendErrorMsg("DIAG: Gyro drift excessive");
        }
    } else {
        diag.mpuGyroOk = false;
        diag.totalFaults++;
    }

    // --- BMP280 Tests ---

    // Test 4: Chip ID
    uint8_t bmpId = bmpReadReg(BMP280_REG_CHIP_ID);
    diag.bmpChipIdOk = (bmpId == BMP280_CHIP_ID_VALUE);
    if (!diag.bmpChipIdOk) {
        diag.totalFaults++;
        sendErrorMsg("DIAG: BMP280 chip ID failed");
    }

    // Test 5: Pressure range (300-1100 hPa)
    if (bmp.online) {
        bmpReadData();
        diag.bmpPressureOk = (bmp.pressure_hPa > 300.0f && bmp.pressure_hPa < 1100.0f);
        if (!diag.bmpPressureOk) {
            diag.totalFaults++;
            char msg[64];
            snprintf(msg, sizeof(msg), "DIAG: Pressure out of range: %.2f hPa", bmp.pressure_hPa);
            sendErrorMsg(msg);
        }
    } else {
        diag.bmpPressureOk = false;
        diag.totalFaults++;
    }

    // Test 6: Temperature range (-40 to 85°C)
    if (bmp.online) {
        diag.bmpTempOk = (bmp.temperature_C > -40.0f && bmp.temperature_C < 85.0f);
        if (!diag.bmpTempOk) {
            diag.totalFaults++;
            char msg[64];
            snprintf(msg, sizeof(msg), "DIAG: Temperature out of range: %.2f °C", bmp.temperature_C);
            sendErrorMsg(msg);
        }
    } else {
        diag.bmpTempOk = false;
        diag.totalFaults++;
    }

    // --- DS1307 Tests ---

    // Test 7: Oscillator running
    if (rtc.online) {
        I2C_Bus1.beginTransmission(DS1307_ADDR);
        I2C_Bus1.write(DS1307_REG_SECONDS);
        I2C_Bus1.endTransmission(false);
        I2C_Bus1.requestFrom((uint8_t)DS1307_ADDR, (uint8_t)1);
        if (I2C_Bus1.available()) {
            uint8_t secReg = I2C_Bus1.read();
            diag.rtcOscOk = !(secReg & 0x80);  // CH bit should be 0
        } else {
            diag.rtcOscOk = false;
        }
        if (!diag.rtcOscOk) {
            diag.totalFaults++;
            sendErrorMsg("DIAG: RTC oscillator stopped");
        }
    } else {
        diag.rtcOscOk = false;
        diag.totalFaults++;
    }

    // Test 8: RTC time validity
    if (rtc.online) {
        rtcReadTime();
        diag.rtcTimeOk = rtc.valid;
        if (!diag.rtcTimeOk) {
            diag.totalFaults++;
            sendErrorMsg("DIAG: RTC time invalid");
        }
    } else {
        diag.rtcTimeOk = false;
        diag.totalFaults++;
    }

    // --- GPS Test ---

    // Test 9: UART activity
    {
        unsigned long gpsCheckStart = millis();
        diag.gpsUartOk = false;
        while (millis() - gpsCheckStart < 2000) {
            if (Serial1.available()) {
                diag.gpsUartOk = true;
                // Flush the bytes
                while (Serial1.available()) Serial1.read();
                break;
            }
            delay(10);
        }
        if (!diag.gpsUartOk) {
            diag.totalFaults++;
            sendWarningMsg("DIAG: GPS UART no data");
        }
    }

    // --- Battery Test ---

    // Test 10: Battery voltage range (2.8V - 4.3V for LiPo)
    readBattery();
    diag.batteryOk = (battery.voltage > 2.8f && battery.voltage < 4.3f);
    if (!diag.batteryOk) {
        diag.totalFaults++;
        char msg[64];
        snprintf(msg, sizeof(msg), "DIAG: Battery voltage out of range: %.2f V", battery.voltage);
        sendErrorMsg(msg);
    }

    // --- C3 Communication Test ---
    // Send $PING and wait for $PONG (handled asynchronously)
    sendStatusMsg("DIAG: Pinging C3...");
    Serial2.println("$PING");
    diag.waitingForPong = true;
    diag.pingSentMs = millis();
    diag.c3PongReceived = false;

    // NOTE: We don't block here. The PONG will be caught in processC3Commands().
    // checkDiagSchedule() handles the timeout and sends the diag frame.

    // If PONG comes quickly (synchronous check for fast response)
    unsigned long quickWait = millis();
    while (millis() - quickWait < 500) {
        processC3Commands();
        if (diag.c3PongReceived) break;
        delay(10);
    }

    // If we got PONG already, finalize now
    if (diag.c3PongReceived || !diag.waitingForPong) {
        if (!diag.c3PongReceived) {
            diag.totalFaults++;
        }
        char diagFrame[512];
        buildDiagFrame(diagFrame, sizeof(diagFrame));
        sendDiagToC3(diagFrame);
        diag.waitingForPong = false;
    }
    // Otherwise, checkDiagSchedule() will handle timeout and send diag frame
}

void buildDiagFrame(char* buffer, size_t bufSize) {
    snprintf(buffer, bufSize,
        "$DIAG,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d",
        (int)diag.mpuWhoAmIOk,
        (int)diag.mpuAccelOk,
        (int)diag.mpuGyroOk,
        (int)diag.bmpChipIdOk,
        (int)diag.bmpPressureOk,
        (int)diag.bmpTempOk,
        (int)diag.rtcOscOk,
        (int)diag.rtcTimeOk,
        (int)diag.gpsUartOk,
        (int)diag.batteryOk,
        (int)diag.c3PongReceived,
        (int)diag.totalFaults
    );

    char msg[80];
    snprintf(msg, sizeof(msg), "=== DIAGNOSTIC COMPLETE — %d faults ===", diag.totalFaults);
    sendStatusMsg(msg);
}

void sendDiagToC3(const char* diagFrame) {
    // Send via Serial2 (command channel to C3)
    Serial2.println(diagFrame);

    // Also output to debugger
    Serial.print("STATUS:DIAG_FRAME=");
    Serial.println(diagFrame);
}

// ============================================================================
// IMPLEMENTATION — HEALTH SCORE
// ============================================================================

void computeHealthScore() {
    healthScore = 0;

    if (mpu.online)  healthScore += 40;   // Most critical
    if (bmp.online)  healthScore += 30;   // Pressure/submersion
    if (rtc.online && rtc.valid) healthScore += 20;  // Timestamps
    if (gps.online && gps.fixValid) healthScore += 10;  // Location
}

// ============================================================================
// IMPLEMENTATION — STATUS MESSAGE UTILITIES
// ============================================================================

void sendStatusMsg(const char* msg) {
    Serial.print("STATUS:");
    Serial.println(msg);
}

void sendErrorMsg(const char* msg) {
    Serial.print("ERROR:");
    Serial.println(msg);
}

void sendWarningMsg(const char* msg) {
    Serial.print("WARNING:");
    Serial.println(msg);
}

// ============================================================================
// SETUP
// ============================================================================

void setup() {
    // ---- Initialize USB Serial (debugger) ----
    Serial.begin(DEBUG_BAUD);
    unsigned long serialWait = millis();
    while (!Serial && millis() - serialWait < 3000) {
        delay(10);
    }

    Serial.println();
    Serial.println("================================================================");
    Serial.println("  VARUNA FLOOD DETECTION BUOY — ESP32-S3 SENSOR BRAIN");
    Serial.println("  Firmware v1.0.0");
    Serial.println("================================================================");
    Serial.println();

    // ---- Initialize Serial2 (C3 command channel) ----
    Serial2.begin(C3_CMD_BAUD, SERIAL_8N1, C3_CMD_RX_PIN, C3_CMD_TX_PIN);
    sendStatusMsg("Serial2 initialized — C3 command channel on GPIO 43(TX)/44(RX)");

    // ---- Initialize software UART (C3 data channel) ----
    initSoftwareUART();

    // ---- Initialize I2C buses ----
    initI2CBuses();

    // ---- Initialize default configuration ----
    initDefaultConfig();
    initThresholds();

    // ---- Initialize MPU6050 ----
    sendStatusMsg("Initializing MPU6050...");
    if (initMPU6050()) {
        // Run calibration
        calibrateGyroscope();
        calibrateAccelerometer();
    } else {
        sendErrorMsg("MPU6050 initialization FAILED — core measurement unavailable");
    }

    // ---- Initialize BMP280 ----
    sendStatusMsg("Initializing BMP280...");
    if (initBMP280()) {
        bmpEstablishBaseline();
    } else {
        sendErrorMsg("BMP280 initialization FAILED — submersion detection unavailable");
    }

    // ---- Initialize DS1307 RTC ----
    sendStatusMsg("Initializing DS1307 RTC...");
    initDS1307();

    // ---- Initialize GPS ----
    sendStatusMsg("Initializing GPS...");
    initGPS();

    // ---- Initialize Battery ADC ----
    initBatteryADC();
    readBattery();
    {
        char msg[64];
        snprintf(msg, sizeof(msg), "Battery: %.2f V (%.1f%%)", battery.voltage, battery.percent);
        sendStatusMsg(msg);
    }

    // ---- Compute initial health score ----
    computeHealthScore();
    {
        char msg[48];
        snprintf(msg, sizeof(msg), "Health score: %d/100", healthScore);
        sendStatusMsg(msg);
    }

    // ---- Initial sensor reading for baseline ----
    if (mpu.online) {
        for (int i = 0; i < 100; i++) {
            mpuReadSensorData();
            mpuConvertUnits();
            runComplementaryFilter();
            delayMicroseconds(FILTER_PERIOD_US);
        }
        sendStatusMsg("Complementary filter seeded with 100 initial readings");
    }

    // ---- Send initial data frame ----
    {
        computeWaterLevel();
        classifyMode();
        updateAlertLevel();
        computeTransmitInterval();

        char csv[1024];
        buildCSVFrame(csv, sizeof(csv));
        transmitCSVtoC3(csv);
        transmitCSVtoDebugger(csv);
        sampling.lastTransmitMs = millis();
        sendStatusMsg("Initial data frame transmitted");
    }

    Serial.println();
    sendStatusMsg("======== INITIALIZATION COMPLETE — ENTERING MAIN LOOP ========");
    Serial.println();
}

// ============================================================================
// MAIN LOOP
// ============================================================================

void loop() {
    unsigned long loopStart = micros();

    // =====================================================================
    // PHASE 1: SENSOR READING (runs every iteration at ~100Hz)
    // =====================================================================

    // --- Read MPU6050 ---
    if (mpu.online) {
        mpuReadSensorData();
        mpuConvertUnits();
    }

    // --- Run complementary filter ---
    if (mpu.online && mpu.calibrated) {
        runComplementaryFilter();
    }

    // --- Read GPS (non-blocking, process available bytes) ---
    while (Serial1.available()) {
        uint8_t b = Serial1.read();
        gpsProcessByte(b);
    }

    // --- Read BMP280 (less frequently — every 100ms is sufficient) ---
    static unsigned long lastBmpRead = 0;
    if (bmp.online && millis() - lastBmpRead >= 100) {
        bmpReadData();
        lastBmpRead = millis();
    }

    // =====================================================================
    // PHASE 2: FLOOD CLASSIFICATION (runs every iteration)
    // =====================================================================

    if (mpu.online && mpu.calibrated) {
        computeWaterLevel();
        classifyMode();
        updateAlertLevel();
    }

    // =====================================================================
    // PHASE 3: COMMAND PROCESSING (runs every iteration)
    // =====================================================================

    processC3Commands();
    processDebugCommands();

    // =====================================================================
    // PHASE 4: DIAGNOSTIC CHECK
    // =====================================================================

    checkDiagSchedule();

    // =====================================================================
    // PHASE 5: DYNAMIC SAMPLING & TRANSMISSION
    // =====================================================================

    computeTransmitInterval();

    if (isTransmitDue()) {
        // Update rate of rise
        updateRateOfRise();

        // Update session statistics
        updateSessionStats();

        // Read RTC for timestamp
        if (rtc.online) {
            rtcReadTime();
        }

        // Read battery
        readBattery();

        // Build and transmit CSV frame
        char csvFrame[1024];
        buildCSVFrame(csvFrame, sizeof(csvFrame));

        // Stream 1: Software UART → C3 (GPIO 14)
        transmitCSVtoC3(csvFrame);

        // Stream 2: USB Serial → Debugger
        transmitCSVtoDebugger(csvFrame);

        // Update timestamp
        sampling.lastTransmitMs = millis();

        // Debug output for mode awareness
        static uint8_t lastReportedMode = 255;
        if (flood.currentMode != lastReportedMode) {
            lastReportedMode = flood.currentMode;
            const char* modeNames[] = {"SLACK", "TAUT", "FLOOD", "SUBMERGED"};
            const char* alertNames[] = {"GREEN", "YELLOW", "RED", "BLACK"};
            char modeMsg[128];
            snprintf(modeMsg, sizeof(modeMsg),
                     "MODE=%s(%d) ALERT=%s H=%.1fcm ratio=%.2f interval=%lus",
                     modeNames[flood.currentMode], flood.currentMode,
                     alertNames[flood.alertLevel],
                     flood.waterHeight_cm, flood.floodRatio,
                     (unsigned long)sampling.currentIntervalSec);
            sendStatusMsg(modeMsg);
        }
    }

    // =====================================================================
    // PHASE 6: LOOP TIMING (maintain ~100Hz for filter)
    // =====================================================================

    unsigned long loopElapsed = micros() - loopStart;
    if (loopElapsed < FILTER_PERIOD_US) {
        delayMicroseconds(FILTER_PERIOD_US - loopElapsed);
    }
}
