void initI2CBuses() {
    // Bus 0: MPU6050 at 400kHz (fast mode)
    I2C_Bus0.begin(I2C0_SDA, I2C0_SCL, 400000);

    // Bus 1: BMP280 + DS1307 at 100kHz (standard, DS1307 max is 100kHz)
    I2C_Bus1.begin(I2C1_SDA, I2C1_SCL, 100000);

    sendStatusMsg("I2C buses initialized — Bus0(GPIO8/9,400kHz) Bus1(GPIO4/5,100kHz)");
}

bool initMPU6050() {
    mpu.online = false;
    mpu.calibrated = false;

    // Check WHO_AM_I
    uint8_t whoami = mpuReadReg(MPU6050_REG_WHO_AM_I);
    if (whoami != MPU6050_WHO_AM_I_VALUE) {
        char msg[64];
        snprintf(msg, sizeof(msg), "MPU6050 WHO_AM_I failed: got 0x%02X, expected 0x%02X", whoami, MPU6050_WHO_AM_I_VALUE);
        sendErrorMsg(msg);
        return false;
    }

    // Wake up (clear SLEEP bit)
    mpuWriteReg(MPU6050_REG_PWR_MGMT_1, 0x00);
    delay(100);

    // Set clock source to PLL with X-axis gyro reference
    mpuWriteReg(MPU6050_REG_PWR_MGMT_1, 0x01);
    delay(10);

    // Sample rate divider: 200Hz (8kHz / (1 + 39) = 200Hz)
    mpuWriteReg(MPU6050_REG_SMPLRT_DIV, 39);

    // Digital low-pass filter: ~44Hz bandwidth (good for buoy application)
    mpuWriteReg(MPU6050_REG_CONFIG, 0x03);

    // Gyro config: ±250°/s (highest sensitivity)
    mpuWriteReg(MPU6050_REG_GYRO_CONFIG, 0x00);

    // Accel config: ±2g (highest sensitivity)
    mpuWriteReg(MPU6050_REG_ACCEL_CONFIG, 0x00);

    // Enable all axes
    mpuWriteReg(MPU6050_REG_PWR_MGMT_2, 0x00);

    mpu.online = true;

    // Initialize filter state
    mpu.filtTiltX = 0.0f;
    mpu.filtTiltY = 0.0f;
    mpu.correctedTiltX = 0.0f;
    mpu.correctedTiltY = 0.0f;
    mpu.combinedTheta = 0.0f;
    mpu.lateralAccel = 0.0f;
    mpu.lastFusionMicros = micros();

    sendStatusMsg("MPU6050 initialized — ±2g accel, ±250°/s gyro, 200Hz sample, 44Hz DLPF");
    return true;
}

bool initBMP280() {
    bmp.online = false;
    bmp.baselineSet = false;

    // Check chip ID
    uint8_t chipId = bmpReadReg(BMP280_REG_CHIP_ID);
    if (chipId != BMP280_CHIP_ID_VALUE) {
        char msg[64];
        snprintf(msg, sizeof(msg), "BMP280 chip ID failed: got 0x%02X, expected 0x%02X", chipId, BMP280_CHIP_ID_VALUE);
        sendErrorMsg(msg);
        return false;
    }

    // Soft reset
    bmpWriteReg(BMP280_REG_RESET, BMP280_RESET_VALUE);
    delay(100);

    // Wait for NVM copy
    uint8_t status;
    int timeout = 100;
    do {
        status = bmpReadReg(BMP280_REG_STATUS);
        delay(10);
        timeout--;
    } while ((status & 0x01) && timeout > 0);

    // Read calibration data
    bmpReadCalibration();

    // Config register: standby 0.5ms, filter coeff 16, SPI disabled
    // Bits: t_sb[7:5]=000, filter[4:2]=100, spi3w_en[0]=0
    bmpWriteReg(BMP280_REG_CONFIG_REG, 0x10);

    // Ctrl_meas: temp oversampling x2, press oversampling x16, normal mode
    // Bits: osrs_t[7:5]=010, osrs_p[4:2]=101, mode[1:0]=11
    bmpWriteReg(BMP280_REG_CTRL_MEAS, 0x57);

    delay(100);

    bmp.online = true;
    sendStatusMsg("BMP280 initialized — x2 temp OS, x16 press OS, filter 16, normal mode");

    return true;
}

bool initDS1307() {
    rtc.online = false;
    rtc.valid = false;

    // Try to read seconds register
    I2C_Bus1.beginTransmission(DS1307_ADDR);
    I2C_Bus1.write(DS1307_REG_SECONDS);
    uint8_t err = I2C_Bus1.endTransmission();

    if (err != 0) {
        sendErrorMsg("DS1307 not responding on I2C Bus 1");
        return false;
    }

    I2C_Bus1.requestFrom((uint8_t)DS1307_ADDR, (uint8_t)1);
    if (I2C_Bus1.available()) {
        uint8_t secReg = I2C_Bus1.read();
        // Check CH bit (bit 7 of seconds register) — if set, oscillator stopped
        if (secReg & 0x80) {
            sendWarningMsg("DS1307 oscillator stopped (CH=1) — time may be invalid");
            // Clear CH bit to start oscillator
            I2C_Bus1.beginTransmission(DS1307_ADDR);
            I2C_Bus1.write(DS1307_REG_SECONDS);
            I2C_Bus1.write(secReg & 0x7F);  // Clear bit 7
            I2C_Bus1.endTransmission();
        }
    }

    rtc.online = true;

    // Read current time to validate
    rtcReadTime();

    // Basic sanity check
    if (rtc.year >= 2024 && rtc.year <= 2035 && rtc.month >= 1 && rtc.month <= 12) {
        rtc.valid = true;
        char msg[64];
        snprintf(msg, sizeof(msg), "DS1307 initialized — time: %s", rtc.dateTimeStr);
        sendStatusMsg(msg);
    } else {
        rtc.valid = false;
        sendWarningMsg("DS1307 time appears invalid — year/month out of range");
    }

    return true;
}

void initGPS() {
    gps.online = false;
    gps.fixValid = false;
    gps.latitude = 0.0f;
    gps.longitude = 0.0f;
    gps.altitude = 0.0f;
    gps.satellites = 0;
    gps.nmeaBufIdx = 0;
    gps.nmeaReady = false;

    // Initialize UART1 for GPS
    Serial1.begin(GPS_BAUD, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);

    sendStatusMsg("GPS UART1 initialized — 9600 baud on GPIO 6(RX)/7(TX)");

    // Give GPS a moment to start transmitting
    delay(500);

    // Check if any data arrives
    unsigned long startCheck = millis();
    bool dataReceived = false;
    while (millis() - startCheck < 2000) {
        if (Serial1.available()) {
            dataReceived = true;
            break;
        }
        delay(10);
    }

    if (dataReceived) {
        gps.online = true;
        sendStatusMsg("GPS module responding — NMEA data detected");
    } else {
        sendWarningMsg("GPS module not responding — no NMEA data within 2 seconds");
    }
}

void initBatteryADC() {
    analogSetAttenuation(ADC_11db);  // Full range ~0-3.3V
    analogReadResolution(12);        // 12-bit ADC
    pinMode(BATTERY_ADC_PIN, INPUT);

    sendStatusMsg("Battery ADC initialized — GPIO 2, 12-bit, 11dB attenuation");
}

