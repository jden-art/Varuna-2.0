// --- Flood Detection State ---
struct FloodState {
    // Operating mode
    uint8_t currentMode;         // 0=SLACK, 1=TAUT, 2=FLOOD, 3=SUBMERGED
    uint8_t pendingMode;         // Mode being evaluated
    uint8_t persistCount;        // Consecutive readings for pending mode

    // Tether geometry
    float olpLength_cm;          // Tether length L in cm (configurable)

    // Computed values
    float waterHeight_cm;        // H = L × cos(θ) in cm
    float horizontalDist_cm;     // d = L × sin(θ) in cm
    float floodRatio;            // H / L (0.0 to 1.0+)

    // Session statistics
    float peakHeight_cm;
    float minHeight_cm;
    unsigned long sessionStartMs;

    // Rate of change
    float rateOfRise_cm_per_15min;
    float lastHeight_cm;
    unsigned long lastRateCalcMs;

    // Alert classification
    uint8_t alertLevel;          // 0=GREEN, 1=YELLOW, 2=RED, 3=BLACK
    bool sustainedRise;          // Rising continuously

    // Zone classification (for output)
    uint8_t currentZone;         // 0-3 matching mode
    uint8_t responseLevel;       // 0-4 response urgency
} flood;

