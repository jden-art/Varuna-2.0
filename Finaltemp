// Command buffer for Serial2 (C3 commands)
static char c3CmdBuf[128];
static uint8_t c3CmdIdx = 0;

// Command buffer for USB Serial (debugger commands)
static char dbgCmdBuf[128];
static uint8_t dbgCmdIdx = 0;

void processC3Commands() {
    while (Serial2.available()) {
        char c = Serial2.read();
        if (c == '\n' || c == '\r') {
            if (c3CmdIdx > 0) {
                c3CmdBuf[c3CmdIdx] = '\0';
                handleC3Command(c3CmdBuf);
                c3CmdIdx = 0;
            }
        } else if (c3CmdIdx < sizeof(c3CmdBuf) - 1) {
            c3CmdBuf[c3CmdIdx++] = c;
        }
    }
}

void handleC3Command(const char* cmd) {
    char msg[128];

    // --- $CFG,normal_sec,high_sec,h_max_cm ---
    if (strncmp(cmd, "$CFG,", 5) == 0) {
        uint32_t normalSec, highSec;
        float hMaxCm;

        int parsed = sscanf(cmd + 5, "%lu,%lu,%f", &normalSec, &highSec, &hMaxCm);

        if (parsed == 3) {
            // Validate ranges
            if (normalSec < 10) normalSec = 10;
            if (normalSec > 3600) normalSec = 3600;
            if (highSec < 5) highSec = 5;
            if (highSec > normalSec) highSec = normalSec;
            if (hMaxCm < 10.0f) hMaxCm = 10.0f;
            if (hMaxCm > 10000.0f) hMaxCm = 10000.0f;

            sampling.normalRateSec = normalSec;
            sampling.highRateSec = highSec;
            flood.olpLength_cm = hMaxCm;

            snprintf(msg, sizeof(msg),
                     "STATUS:CFG applied — normal=%lus, high=%lus, L=%.1fcm",
                     normalSec, highSec, hMaxCm);
            Serial.println(msg);

            // Acknowledge to C3
            Serial2.println("$CFG_ACK");
        } else {
            Serial2.println("$CFG_ERR,PARSE_FAIL");
            sendErrorMsg("$CFG parse failed — expected $CFG,normal,high,hmax");
        }
        return;
    }

    // --- $DIAGRUN ---
    if (strcmp(cmd, "$DIAGRUN") == 0) {
        diag.diagRequested = true;
        Serial2.println("$DIAGRUN_ACK");
        sendStatusMsg("Diagnostic run requested by C3");
        return;
    }

    // --- $PING ---
    if (strcmp(cmd, "$PING") == 0) {
        Serial2.println("$PONG");
        sendStatusMsg("PING received from C3 — PONG sent");
        return;
    }

    // --- $PONG (response to our diagnostic ping) ---
    if (strcmp(cmd, "$PONG") == 0) {
        if (diag.waitingForPong) {
            diag.c3PongReceived = true;
            diag.waitingForPong = false;
            sendStatusMsg("PONG received from C3 — link verified");
        }
        return;
    }

    // Unknown command
    snprintf(msg, sizeof(msg), "WARNING:Unknown C3 command: %s", cmd);
    Serial.println(msg);
}

